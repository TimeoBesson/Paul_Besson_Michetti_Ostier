<UserControl x:Class="Paul_Besson_Michetti_Ostier.Windows.UC_Chef"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Paul_Besson_Michetti_Ostier.Windows"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800"  Height="450" Width="800" Background="#FFD4C3C1">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="3*"/>
            <ColumnDefinition Width="37*"/>
        </Grid.ColumnDefinitions>
        <Image Margin="0,0,675,309" Source="/Images/Logo_Paul.png" Stretch="Fill" Grid.ColumnSpan="2" Width="125" Height="125"/>
        <TabControl HorizontalAlignment="Left" VerticalAlignment="Top" Height="450" Width="800" TabStripPlacement="Left"  BorderBrush="Transparent" Background="Transparent" BorderThickness="0" SelectionChanged="TabControl_SelectionChanged" Grid.ColumnSpan="2">
            <TabItem Header="Gerer Commandes" Margin="-2,175,2,-175" Background="Transparent" Width="120">
                <Grid Background="Aqua" Height="460" Width="675"/>
            </TabItem>
            <TabItem Header="Gerer les Produits" Margin="-2,208,0,-208" Background="Transparent" Height="25" Width="120">
                <Grid Background="Green" Height="450" Width="675"/>
            </TabItem>

        </TabControl>
        <Label Content="Chef Boulanger\Pâtissier" Foreground="#FF504443" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="0,130,0,0" Grid.ColumnSpan="2" FontSize="10" FontFamily="Work Sans" FontWeight="Bold"/>
    </Grid>
</UserControl>
