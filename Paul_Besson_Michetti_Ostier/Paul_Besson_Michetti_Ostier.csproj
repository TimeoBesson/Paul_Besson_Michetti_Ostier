<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net8.0-windows</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <UseWPF>true</UseWPF>
  </PropertyGroup>

  <ItemGroup>
    <None Remove="Images\Icone_cadenas.png" />
    <None Remove="Images\Icone_croissant.png" />
    <None Remove="Images\Icone_face.png" />
    <None Remove="Images\Icone_gérer_commandes.png" />
    <None Remove="Images\Icone_gérer_produits.png" />
    <None Remove="Images\Icone_sortie.png" />
    <None Remove="Images\Image_fraisier.png" />
